# Runtime
SUPPORTSMITH_ENVIRONMENT=local
SUPPORTSMITH_LOG_LEVEL=INFO

# Database
# Use this value with `docker compose up postgres`.
DATABASE_URL=postgresql://supportsmith:supportsmith@localhost:55432/supportsmith

# OpenAI
# CHAT_MODEL = predictable conversational model (no internal reasoning overhead).
# REASONING_MODEL = use when a node genuinely benefits from chain-of-thought
# reasoning (planning, hard routing). Pick per-node in the agent graph.
OPENAI_API_KEY=
SUPPORTSMITH_CHAT_MODEL=gpt-5.5
SUPPORTSMITH_REASONING_MODEL=gpt-5.5
SUPPORTSMITH_EMBEDDING_MODEL=text-embedding-3-small

# Eval judge
# Used when `supportsmith-eval --judge llm` is enabled.
SUPPORTSMITH_JUDGE_MODEL=gpt-5.5
SUPPORTSMITH_JUDGE_REASONING_EFFORT=low
SUPPORTSMITH_JUDGE_MAX_COMPLETION_TOKENS=1024

# LangSmith tracing
# Enable for live/demo tracing; tests and offline evals can leave it disabled.
LANGSMITH_TRACING=false
LANGSMITH_API_KEY=
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
LANGSMITH_PROJECT=supportsmith-agent

# Demo API gate
# Required on public deployments. Every API route except /health and /ui*
# requires `Authorization: Bearer <token>` when this is set. Leave blank
# for local dev to disable the gate.
SUPPORTSMITH_API_BEARER_TOKEN=

# Firecrawl (website ingestion)
# Required for `supportsmith-ingest-website` and the admin ingestion API.
SUPPORTSMITH_FIRECRAWL_API_KEY=

# Admin ingestion gate
# Additional credential the /admin/* ingestion routes require on top of the
# demo bearer token.
SUPPORTSMITH_ADMIN_API_KEY=
# Comma-separated hostnames the admin ingestion API will accept.
SUPPORTSMITH_ALLOWED_INGESTION_HOSTS=knotch.com
# Set true to allow ingestion of any public host (allowlist still applies first).
SUPPORTSMITH_ALLOW_ANY_WEBSITE_INGESTION=false
